body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #f4f4f4;
    text-align: center;
}

header {
    background: black;
    color: white;
    padding: 40px;
}

h1 {
    margin: 0;
    font-size: 40px;
}

.about {
    padding: 40px;
}

.portfolio {
    padding: 40px;
    background: white;
}

.gallery {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
}

.art {
    width: 200px;
    height: 200px;
    background: #ddd;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
}

footer {
    background: black;
    color: white;
    padding: 20px;
}
